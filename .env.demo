# Minimal config for demo (no CRM)
# Copy to .env and add your keys

VAPI_API_KEY=
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash  # optional, default

# For web call widget (public/call.html) – get from VAPI Dashboard
VAPI_PUBLIC_API_KEY=
VAPI_ASSISTANT_ID=

# For outbound calls – get from VAPI Dashboard → Phone Numbers
VAPI_PHONE_NUMBER_ID=

# Omit CRM_PROVIDER for JSON-only demo
# CRM_PROVIDER=

PORT=3000
